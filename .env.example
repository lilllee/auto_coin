# Upbit API (주문 권한만, 출금 비활성, IP 화이트리스트 설정 필수)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Telegram 알림 (선택 — 비우면 콘솔 로그만)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 실행 모드
# paper: 시세 수신 + 주문은 로그만 (기본)
# live : 실거래 (명시적으로 설정해야 함)
MODE=paper
LIVE_TRADING=0
KILL_SWITCH=0

# 웹 인증
# 기본값은 로그인 없이 바로 진입.
# setup/login/TOTP 보호 흐름을 다시 켜려면 ENABLE_AUTH=1
ENABLE_AUTH=0

# 매매 대상 — 둘 중 하나
# (A) 단일 종목: TICKER만 설정, TICKERS는 비워둠
# (B) 멀티 종목(포트폴리오): TICKERS에 콤마로 나열. 진입 우선순위는 나열 순서.
TICKER=KRW-BTC
TICKERS=
MAX_CONCURRENT_POSITIONS=3

# 관측 전용 티커 (주문 없음, 콤마 구분). 매매 대상과 중복 제거됨.
WATCH_TICKERS=
WATCH_INTERVAL_MINUTES=15

# 전략 파라미터 — 변동성 돌파
STRATEGY_K=0.5
MA_FILTER_WINDOW=5

# 리스크 관리
MAX_POSITION_RATIO=0.20
DAILY_LOSS_LIMIT=-0.03
STOP_LOSS_RATIO=-0.02
MIN_ORDER_KRW=5000
API_MAX_RETRIES=3

# 페이퍼 가상 잔고 + 스케줄 파라미터
PAPER_INITIAL_KRW=1000000
CHECK_INTERVAL_SECONDS=30   # tick 주기. 30초 미만은 floor로 막힘 (max_instances skip 방지)
HEARTBEAT_INTERVAL_HOURS=6   # 0이면 heartbeat 비활성
EXIT_HOUR_KST=8
EXIT_MINUTE_KST=55
DAILY_RESET_HOUR_KST=9
STATE_DIR=state

# 로그
LOG_LEVEL=INFO
LOG_DIR=logs


USE_WEBSOCKET=true
